RESEND_API_KEY=re_your_api_key_here
CONTACT_FROM_EMAIL=contact@eosbot.ai
CONTACT_FROM_NAME=Upaway Contact

# Preview hub (/preview). These are public browser-exposed Vite variables; do not put secrets here.
VITE_PREVIEW_TRUESPACE_URL=
VITE_PREVIEW_TRUESPACE_LOCAL_URL=http://localhost:3000
VITE_PREVIEW_TRUESPACE_API_URL=http://127.0.0.1:7777/v1/heartbeat
VITE_PREVIEW_TRUESPACE_DOCS_URL=http://127.0.0.1:8888
VITE_PREVIEW_TRUESPACE_STORYBOOK_URL=http://127.0.0.1:6006

# Preview runner. Leave disabled on Vercel/serverless hosts.
# Enable this only on a machine that has the preview source checkouts and can run long-lived processes.
PREVIEW_RUNNER_ENABLED=
PREVIEW_RUNNER_TOKEN=
PREVIEW_RUNNER_LOG_DIR=
PREVIEW_REMOTE_RUNNER_URL=
